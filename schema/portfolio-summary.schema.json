{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portfolio Summary",
  "type": "object",
  "required": [
    "generated_at",
    "projects_active",
    "projects_closed",
    "projects_unclassified",
    "followup_urgent",
    "followup_pending",
    "followup_snooze",
    "commercial_flags_high",
    "commercial_flags_medium",
    "revenue_total_eur",
    "invoices_total",
    "ledger_template_only_count"
  ],
  "properties": {
    "generated_at": { "type": "string" },
    "projects_active": { "type": "integer", "minimum": 0 },
    "projects_closed": { "type": "integer", "minimum": 0 },
    "projects_unclassified": { "type": "integer", "minimum": 0 },
    "followup_urgent": { "type": "integer", "minimum": 0 },
    "followup_pending": { "type": "integer", "minimum": 0 },
    "followup_snooze": { "type": "integer", "minimum": 0 },
    "commercial_flags_high": { "type": "integer", "minimum": 0 },
    "commercial_flags_medium": { "type": "integer", "minimum": 0 },
    "revenue_total_eur": { "type": "number" },
    "invoices_total": { "type": "integer", "minimum": 0 },
    "ledger_template_only_count": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
